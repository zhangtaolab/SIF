{
  "mcpServers": {
    "sif": {
      "command": "python",
      "args": [
        "-m",
        "sif.mcp.transport_stdio"
      ],
      "env": {
        "PYTHONPATH": "/path/to/sif/src"
      },
      "description": "SIF MCP Server for document search and retrieval",
      "disabled": false
    }
  }
}
