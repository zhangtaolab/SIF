{
  "mcpServers": {
    "docsift": {
      "command": "python",
      "args": [
        "-m",
        "docsift.mcp.transport_stdio"
      ],
      "env": {
        "PYTHONPATH": "/path/to/docsift/src"
      },
      "description": "DocSift MCP Server for document search and retrieval",
      "disabled": false
    }
  }
}
